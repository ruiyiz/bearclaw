{
  "name": "nanoclaw",
  "version": "2026.5.7",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nanoclaw": "./dist/tui/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/scripts/whatsapp-auth.ts",
    "tui": "bun src/tui/cli.tsx tui",
    "tui:dev": "bun --watch src/tui/cli.tsx tui",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.4",
    "node-pty": "^1.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "protobufjs": "^7.5.5",
    "@anthropic-ai/sdk": ">=0.91.1"
  }
}
